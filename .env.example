# PostgreSQL connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# API server
API_PORT=8000
PORT=8000

# Internal URL the MCP server uses to reach the API
# In Docker Compose: http://fedscrape_api:8000
# In Railway: set to the internal Railway service URL
API_BASE_URL=http://localhost:8000

# Redis (rate limiting + caching)
REDIS_URL=redis://localhost:6379

# Set to "test" to disable rate limiting in tests (CI sets this automatically)
APP_ENV=

# AWS / S3 (optional — leave blank to skip upload)
AWS_KEY=
AWS_SECRET=
AWS_REGION=
S3_BUCKET=

# Anthropic (required for /chat endpoint)
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
